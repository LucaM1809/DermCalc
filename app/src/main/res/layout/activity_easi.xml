<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EasiActivity">

    <!-- barra in alto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/topBar"
        android:background="@color/primary_easi"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="EASI"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvNomePaziente"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Nome Paziente"
            android:textColor="@color/white"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvDataVisita"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Data Visita"
            android:textColor="@color/white"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- zona dati -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding = "16dp"
        android:clipToPadding="false"

        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnCalcolaEasi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- distretto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"

                android:text="Distretto (H testa, U, Arti sup., T tronco, L Arti inf.)"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <RadioGroup
                android:id="@+id/rgDistretto"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbTesta"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="H"
                    android:gravity="center"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbArtiSup"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="U"
                    android:gravity="center"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbTronco"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="T"
                    android:gravity="center"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbArtiInf"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="L"
                    android:gravity="center"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:checked="false" />
            </RadioGroup>

            <!-- eritema -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"

                android:text = "Eritema"
                android:textSize="15sp"/>

            <RadioGroup
                android:id="@+id/rgEritema"

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbEr0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="0"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbEr1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="1"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbEr2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="2"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbEr3"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="3"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />
                


            </RadioGroup>

            <!-- edema -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"

                android:text = "Edema"
                android:textSize="15sp"/>

            <RadioGroup
                android:id="@+id/rgEdema"

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbEd0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="0"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbEd1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="1"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbEd2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="2"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbEd3"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="3"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />
                


            </RadioGroup>

            <!-- escoriazione -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"

                android:text = "escoriazione"
                android:textSize="15sp"/>

            <RadioGroup
                android:id="@+id/rgEscoriazione"

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbEx0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="0"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbEx1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="1"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbEx2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="2"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbEx3"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="3"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />
                


            </RadioGroup>
            
            
            <!-- lichenification -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"

                android:text = "Lichenificazione"
                android:textSize="15sp"/>

            <RadioGroup
                android:id="@+id/rgLichen"

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbL0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="0"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbL1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="1"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbL2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="2"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />

                <RadioButton
                    android:id="@+id/rbL3"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:text="3"
                    android:gravity="center"
                    app:buttonTint="@color/color_radio_selector_easi"
                    android:background="@drawable/bg_radio_selector_easi"
                    android:textColor="@color/color_radio_selector_easi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:checked="false" />
            </RadioGroup>

            <!-- area -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Area coinvolta (0-100%) (Senza %)"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/Area"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:hint="es. 35"
                android:inputType="number"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnSalvaDistretto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/primary_easi"

                android:text="Salva distretto"
                android:textColor="@color/white" />
            <TextView

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="NON SALVARE IL DISTRETTO SE\n- È l'ultimo distretto considerato nel calcolo\n- È l'unico distretto considerato nel calcolo\nIn questi casi salvare e calcolare direttamente"
                android:textColor="@color/primary_easi"
                android:textSize="18sp"/>
        </LinearLayout>

    </ScrollView>


    <!-- button calcola -->
    <Button
        android:id="@+id/btnCalcolaEasi"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/primary_easi"

        android:text="Salva e calcola EASI"
        android:textColor="@color/white"
        android:textSize="15sp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>