<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BmiActivity">

    <!-- barra in alto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/topBar"
        android:background="@color/primary_blue"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Pasi"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvNomePaziente"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Nome Paziente"
            android:textColor="@color/white"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvDataVisita"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Data Visita"
            android:textColor="@color/white"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- zona centrale -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_vertical"

        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnCalcolaPasi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- zona dati -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"

            android:text="Distretto (H testa, U, Arti sup., T tronco, L Arti inf.)"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

        <RadioGroup
            android:id="@+id/rgDistretto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbTesta"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="H"
                android:gravity="center"
                android:background="@drawable/bg_radio_selector"
                android:textColor="@color/color_radio_selector"
                app:buttonTint="@color/color_radio_selector"
                android:textSize="16sp"
                android:textStyle="bold"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbArtiSup"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="U"
                android:gravity="center"
                android:background="@drawable/bg_radio_selector"
                android:textColor="@color/color_radio_selector"
                app:buttonTint="@color/color_radio_selector"
                android:textSize="16sp"
                android:textStyle="bold"
                android:checked="false" />

            <RadioButton
                android:id="@+id/rbTronco"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="T"
                android:gravity="center"
                android:background="@drawable/bg_radio_selector"
                android:textColor="@color/color_radio_selector"
                app:buttonTint="@color/color_radio_selector"
                android:textSize="16sp"
                android:textStyle="bold"
                android:checked="false" />

            <RadioButton
                android:id="@+id/rbArtiInf"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="L"
                android:gravity="center"
                android:background="@drawable/bg_radio_selector"
                android:textColor="@color/color_radio_selector"
                app:buttonTint="@color/color_radio_selector"
                android:textSize="16sp"
                android:textStyle="bold"
                android:checked="false" />

        </RadioGroup>



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"

            android:text="Peso (KG)"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

        <EditText
            android:id="@+id/Peso"

            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:padding="12dp"
            android:background="@drawable/bg_input"

            android:hint="es. 70"
            android:inputType="numberDecimal"

            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"

            android:text="Altezza (CM)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

        <EditText
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:id="@+id/Altezza"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_input"
            android:hint="es. 175"
            android:inputType="numberDecimal"
            android:padding="12dp"

            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- button calcola -->
    <Button
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:id="@+id/btnCalcolaPasi"

        android:backgroundTint="@color/primary_blue"

        android:text="Calcola BMI"
        android:textColor="@color/white"
        android:textSize="20sp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>