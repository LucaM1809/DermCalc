<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity_pasi_result">

    <!-- barra in alto (presa dall'activity)-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/topBar"
        android:background="@color/primary_blue"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="PASI"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvNomePaziente"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Nome Paziente"
            android:textColor="@color/white"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvDataVisita"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Data Visita"
            android:textColor="@color/white"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- risultato e analisi del risultato -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnTorna"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- RISULTATO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvValorePasi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvClassePasi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- TABELLA GRADI SEVERITÀ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gradi di severità"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvGrado1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lieve - PASI &lt;= 10"
                    android:textSize="17sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Moderato - PASI &lt; 20"
                    android:textSize="17sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Severo - PASI &gt;= 20"
                    android:textSize="17sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />


            </LinearLayout>

            <!-- FONTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fonte"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvFonte"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="La Pelle Conta, Psoriasi, Esami e Diagnosi - PASI"
                    android:textColor="@color/primary_blue"
                    android:textSize="17sp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
    <!-- button torna alla home -->
    <Button
        android:id="@+id/btnTorna"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/primary_blue"
        android:text="Torna alla visita"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>