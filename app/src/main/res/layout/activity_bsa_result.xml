<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity_bmi_result">

    <!-- barra in alto (presa dall'activity)-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/topBar"
        android:background="@color/primary_bsa"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="BSA"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvNomePaziente"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Nome Paziente"
            android:textColor="@color/white"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/tvDataVisita"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Data Visita"
            android:textColor="@color/white"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- risultato -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnTorna"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- risultato -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvValoreBsa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_bsa"/>

                <TextView
                    android:id="@+id/tvSuperficieBsa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvClasseBsa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_bsa"/>

            </LinearLayout>

            <!-- gradi di severità -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gradi di severità"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvGrado1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lieve — BSA &lt;= 10%"
                    android:textSize="15sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Moderata — 10% &lt; BSA &lt;= 20%"
                    android:textSize="15sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Grave — BSA &gt; 20%"
                    android:textSize="15sp"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- FONTI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fonti"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvFonte1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calcolatrice.now - Calcolatore BSA"
                    android:textColor="@color/primary_bsa"
                    android:textSize="15sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvFonte2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Il dermatologo risponde - Superficie cutanea BSA"
                    android:textColor="@color/primary_bsa"
                    android:textSize="15sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvFonte3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Consulto con medico di medicina generale\nDott.sa Andricciola Chiara"
                    android:textColor="@color/primary_bsa"
                    android:textSize="15sp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
    <!-- button torna alla home -->
    <Button
        android:id="@+id/btnTorna"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/primary_bsa"
        android:text="Torna alla visita"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>