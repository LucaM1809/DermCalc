<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_blue"
        android:orientation="vertical"
        android:padding="16dp"
        tools:ignore="MissingConstraints">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DermCalc"
            android:textColor="@color/white"
            android:textSize="20dp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nuova Visita"
            android:textColor="@color/light_blue"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- schermata centrale scorrevole -->
    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="16dp"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="-16dp"
        tools:layout_editor_absoluteY="77dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <!-- generalità paziente -->
            <LinearLayout
                android:id="@+id/cardPaziente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paziente"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/Nome"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:hint="Nome e Cognome"
                    android:inputType="textPersonName"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/DDN"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Data di Nascita"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/CodFis"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:hint="Codice Fiscale"
                    android:inputType="textCapCharacters"
                    android:maxLength="16"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- pulsante salva -->
            <Button
                android:id="@+id/SalvaPaziente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary_blue"
                android:padding="14dp"
                android:text="Salva e inizia visita"
                android:textColor="@color/white" />

            <!-- button calcolo indici -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:columnCount="2"
                android:rowCount="2">

                <Button
                    android:id="@+id/btnPasi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"

                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:text="PASI\nPsoriasi"

                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnEasi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"

                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:text="EASI\nDermatite Atopica"

                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnBmi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"

                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:text="BMI\nBody Mass Index"

                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnBsa"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"

                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:text="BSA\nBody Surface Area"

                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

            </GridLayout>

            <!-- report -->
            <Button
                android:id="@+id/btnReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/primary_blue"
                android:padding="14dp"
                android:text="Genera Report Completo"
                android:textColor="@color/white" />

        </LinearLayout>

    </ScrollView>

    <!-- navbar sotto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_blue"
        android:orientation="horizontal"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="833dp">

            <Button
                android:id="@+id/btnNavVisita"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Visita"
                android:textColor="@color/white"
                android:background="@android:color/transparent" />

            <Button
                android:id="@+id/btnNavPazienti"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="DB Pazienti"
                android:textColor="@color/white"
                android:background="@android:color/transparent" />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>