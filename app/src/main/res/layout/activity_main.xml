<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_grey">



    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_blue"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DermCalc"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nuova Visita"
            android:textColor="@color/light_blue"
            android:textSize="13sp" />


    </LinearLayout>



    <!-- schermata centrale scorrevole -->
    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="true"
        android:paddingBottom="0dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayout"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical">

            <!-- paziente già loggato -->
            <LinearLayout
                android:id="@+id/cardPazienteEsistente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paziente già visitato"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/CodFisEsistente"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:hint="Codice fiscale"
                    android:maxLength="16"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnCercaPaziente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/primary_blue"
                    android:text="Cerca paziente"
                    android:textColor="@color/white" />

            </LinearLayout>
            <Button
                android:id="@+id/btnNuovaVisita"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/primary_blue"
                android:text="Nuova visita"
                android:textColor="@color/white" />
            <!-- generalità paziente -->
            <LinearLayout
                android:id="@+id/cardPaziente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paziente"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/Nome"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:hint="Nome e Cognome"
                    android:inputType="textPersonName"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/DDN"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Data di Nascita"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/CodFis"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:hint="Codice Fiscale"
                    android:maxLength="16"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- pulsante salva -->
            <Button
                android:id="@+id/SalvaPaziente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary_blue"
                android:padding="14dp"
                android:text="Salva e inizia visita"
                android:textColor="@color/white" />

            <!-- button calcolo indici -->
            <GridLayout
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:padding="16dp"
                android:background="@color/background_grey">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnPasi"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp"
                    android:text="PASI\nPsoriasi"
                    android:textColor="#0C447C"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_pasi"
                    android:stateListAnimator="@null" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnEasi"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp"
                    android:text="EASI\nDermatite Atopica"
                    android:textColor="#27500A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_easi"
                    android:stateListAnimator="@null" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBmi"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp"
                    android:text="BMI\nBody Mass Index"
                    android:textColor="#633806"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_bmi"
                    android:stateListAnimator="@null" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBsa"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="8dp"
                    android:text="BSA\nBody Surface Area"
                    android:textColor="#72243E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_bsa"
                    android:stateListAnimator="@null" />

            </GridLayout>

            <!-- report -->
            <Button
                android:id="@+id/btnReport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/primary_blue"
                android:padding="14dp"
                android:text="Genera Report Completo"
                android:textColor="@color/white" />

        </LinearLayout>

    </ScrollView>

    <!-- navbar sotto -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_blue"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btnNavVisita"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Visita"
                android:textColor="@color/white"
                android:background="@android:color/transparent" />

            <Button
                android:id="@+id/btnNavPazienti"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="DB Pazienti"
                android:textColor="@color/white"
                android:background="@android:color/transparent" />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>