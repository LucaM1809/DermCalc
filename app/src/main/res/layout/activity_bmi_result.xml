<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity_bmi_result">

    <!-- barra in alto (presa dall'activity)-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/topBar"
        android:background="@color/primary_bmi"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="BMI"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvNomePaziente"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Nome Paziente"
            android:textColor="@color/white"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvDataVisita"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:text="Data Visita"
            android:textColor="@color/white"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- risultato e analisi del risultato -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnTorna"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- RISULTATO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvValoreBmi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvClasseBmi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- TABELLA GRADI SEVERITÀ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gradi di severità"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvGrado1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sottopeso severo — BMI &lt; 16.0"
                    android:textSize="13sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sottopeso moderato — 16.0 / 16.99"
                    android:textSize="13sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sottopeso lieve — 17.0 / 18.49"
                    android:textSize="13sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Normopeso — 18.5 / 24.99"
                    android:textSize="13sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sovrappeso — 25.0 / 29.99"
                    android:textSize="13sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Obesità I (moderata) — 30.0 / 34.99"
                    android:textSize="13sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Obesità II (severa) — 35.0 / 39.99"
                    android:textSize="13sp"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvGrado8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Obesità III (grave) — BMI ≥ 40.0"
                    android:textSize="13sp"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- FONTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fonte"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvFonte"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="leaderfarmablog.it — BMI Indice di Massa Corporea"
                    android:textColor="@color/primary_bmi"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
    <!-- button torna alla home -->
    <Button
        android:id="@+id/btnTorna"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="@color/primary_bmi"
        android:text="Torna alla visita"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>